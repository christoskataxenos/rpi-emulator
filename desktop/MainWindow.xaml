<Window x:Class="RpiEmulatorDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RpiEmulatorDesktop"
        mc:Ignorable="d"
        Title="Virtual Raspberry Pi Educational Simulator" Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="#18181B" Foreground="#E3E3E3"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Στυλ για τα Panels -->
        <Style x:Key="PanelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E3E3E3"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Στυλ για τα Κουμπιά -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E3E3E3"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RunButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#C51A4A"/>
            <Setter Property="BorderBrush" Value="#A01239"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0245E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Στυλ για το Pin Grid Item -->
        <Style x:Key="PinItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#18181B" Foreground="#E3E3E3" Padding="5,2">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#E3E3E3"/>
                    <Setter Property="Background" Value="#18181B"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3E3E42"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.Resources>
            <MenuItem Header="Αρχείο">
                <MenuItem Header="Νέο Project" Click="MenuNew_Click"/>
                <MenuItem Header="Άνοιγμα Project..." Click="MenuLoad_Click"/>
                <MenuItem Header="Αποθήκευση Project..." Click="MenuSave_Click"/>
                <Separator Background="#3F3F46"/>
                <MenuItem Header="Έξοδος" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Επεξεργασία">
                <MenuItem Header="Αναίρεση" Click="MenuUndo_Click"/>
                <MenuItem Header="Καθαρισμός Κυκλώματος" Click="MenuClear_Click"/>
            </MenuItem>
            <MenuItem Header="Προβολή">
                <MenuItem Header="Εναλλαγή Θέματος" Click="MenuThemeToggle_Click"/>
            </MenuItem>
            <MenuItem Header="Βοήθεια">
                <MenuItem Header="Περί..." Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- 1. Αριστερή Στήλη: Σενάρια & Οδηγίες -->
            <ColumnDefinition Width="280" MinWidth="180"/>
            <!-- Splitter 1 -->
            <ColumnDefinition Width="5"/>
            <!-- 2. Μεσαία Στήλη: Editor & Console -->
            <ColumnDefinition Width="*" MinWidth="300"/>
            <!-- Splitter 2 -->
            <ColumnDefinition Width="5"/>
            <!-- 3. Δεξιά Στήλη: RPi GPIO Pins -->
            <ColumnDefinition Width="340" MinWidth="240"/>
        </Grid.ColumnDefinitions>

        <!-- ================= ΑΡΙΣΤΕΡΗ ΣΤΗΛΗ ================= -->
        <!-- GridSplitter 1: μεταξύ αριστερής και μεσαίας στήλης -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#3F3F46" ShowsPreview="False"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>
        <!-- GridSplitter 2: μεταξύ μεσαίας και δεξιάς στήλης -->
        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#3F3F46" ShowsPreview="False"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>
        <!-- ================================================== -->
        <Grid Grid.Column="0" Margin="0,0,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ΜΑΘΗΜΑΤΑ / ΣΕΝΑΡΙΑ" Style="{StaticResource PanelHeaderStyle}"/>
            
            <ListBox x:Name="ScenariosListBox" Grid.Row="1" 
                     Background="#252526" BorderBrush="#3F3F46" Foreground="#E3E3E3"
                     SelectionChanged="ScenariosListBox_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="3">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="#E3E3E3"/>
                            <TextBlock Text="{Binding Difficulty}" FontSize="11" Foreground="#A0A0A0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Text="ΟΔΗΓΙΕΣ ΣΕΝΑΡΙΟΥ" Style="{StaticResource PanelHeaderStyle}" Margin="0,15,0,5"/>
            
            <Border Grid.Row="3" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ScenarioReadmeText" TextWrapping="Wrap" Margin="10" 
                               FontFamily="Segoe UI" FontSize="12" Foreground="#D4D4D4"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ================= ΜΕΣΑΙΑ ΣΤΗΛΗ ================= -->
        <Grid Grid.Column="2" Margin="5,0,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="1.7*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Αριστερό Μέρος: Editor & Console -->
            <Grid Grid.Column="0" Margin="0,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="180" MinHeight="80"/>
                </Grid.RowDefinitions>

                <!-- Header & Buttons -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ΚΩΔΙΚΑΣ PYTHON" Style="{StaticResource PanelHeaderStyle}"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="StatusLabel" Text="Έτοιμο" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#A0A0A0" FontSize="11"/>
                        <Button x:Name="RunButton" Content="Run" Style="{StaticResource RunButtonStyle}" Width="50" Click="RunButton_Click"/>
                        <Button x:Name="StopButton" Content="Stop" Style="{StaticResource ModernButtonStyle}" Width="50" Click="StopButton_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>

                <!-- Editor -->
                <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Background="#1D1D1D">
                    <TextBox x:Name="CodeEditor" AcceptsReturn="True" AcceptsTab="True" 
                             FontFamily="Consolas" FontSize="13" 
                             Background="Transparent" Foreground="#D4D4D4" 
                             BorderThickness="0" Padding="8"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Console Header -->
                <TextBlock Grid.Row="2" Text="ΚΟΝΣΟΛΑ ΕΞΟΔΟΥ" Style="{StaticResource PanelHeaderStyle}" Margin="0,15,0,5"/>

                <!-- Splitter Editor-Console -->
                <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="#3F3F46" ShowsPreview="False"
                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

                <!-- Output Console -->
                <Border Grid.Row="4" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Background="#121212">
                    <TextBox x:Name="ConsoleOutput" IsReadOnly="True" AcceptsReturn="True"
                             FontFamily="Consolas" FontSize="12" 
                             Background="Transparent" Foreground="#00FF00" 
                             BorderThickness="0" Padding="8"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </Grid>

            <!-- Splitter μεταξύ Editor και Canvas -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#3F3F46" ShowsPreview="False"
                          ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

            <!-- Δεξί Μέρος: Καμβάς Σχεδίασης & Λίστα Εξαρτημάτων -->
            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Warning Banner για Βραχυκυκλώματα (Κοινό) -->
                <Border x:Name="WarningBanner" Grid.Row="0" Background="#B3C51A4A" BorderBrush="#C51A4A" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10" Visibility="Collapsed" Panel.ZIndex="100">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="WarningText" Text="Ανιχνεύθηκε βραχυκύκλωμα!" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Width="200"/>
                    </StackPanel>
                </Border>

                <!-- Tab Control για εναλλαγή Καμβά / Λίστας -->
                <TabControl Grid.Row="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                    <TabControl.Resources>
                        <!-- Custom στυλ για τα Tab Items -->
                        <Style TargetType="TabItem">
                            <Setter Property="Header" Value="{Binding Header}"/>
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="Foreground" Value="#A0A0A0"/>
                            <Setter Property="BorderBrush" Value="#3F3F46"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0" CornerRadius="3,3,0,0" Margin="2,0">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#252526"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- TAB 1: ΚΑΜΒΑΣ ΣΧΕΔΙΑΣΗΣ -->
                    <TabItem Header="Καμβάς Σχεδίασης">
                        <Grid Background="#1E1E1E">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar Καμβά -->
                            <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="5">
                                <WrapPanel VerticalAlignment="Center">
                                    <!-- LED DropDown με χρωματική επιλογή -->
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <Button x:Name="AddLedButton" Content="+ LED" Style="{StaticResource ModernButtonStyle}" FontSize="10"
                                                Click="AddLedDropdown_Click">
                                            <Button.ContextMenu>
                                                <ContextMenu x:Name="LedColorMenu" Background="#2D2D2D" BorderBrush="#3F3F46">
                                                    <MenuItem Header="🔴  Κόκκινο"   Tag="red"    Click="AddLedColor_Click" Foreground="#FF3B30" FontWeight="SemiBold"/>
                                                    <MenuItem Header="🟢  Πράσινο"   Tag="green"  Click="AddLedColor_Click" Foreground="#4CD964" FontWeight="SemiBold"/>
                                                    <MenuItem Header="🟡  Κίτρινο"   Tag="yellow" Click="AddLedColor_Click" Foreground="#FFCC00" FontWeight="SemiBold"/>
                                                    <MenuItem Header="🔵  Μπλε"     Tag="blue"   Click="AddLedColor_Click" Foreground="#0A84FF" FontWeight="SemiBold"/>
                                                    <MenuItem Header="⚪  Λευκό"    Tag="white"  Click="AddLedColor_Click" Foreground="#F0F0F0" FontWeight="SemiBold"/>
                                                    <MenuItem Header="🟠  Πορτοκαλί" Tag="orange" Click="AddLedColor_Click" Foreground="#FF9500" FontWeight="SemiBold"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </StackPanel>
                                    <Button Content="+ Resistor" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddResistor_Click" Margin="2"/>
                                    <Button Content="+ Button" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddButton_Click" Margin="2"/>
                                    <Button Content="+ Buzzer" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddBuzzer_Click" Margin="2"/>
                                    <Button Content="+ DHT11" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddDht11_Click" Margin="2"/>
                                    <Button Content="+ PIR" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddPir_Click" Margin="2"/>
                                    <Button Content="+ LDR" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddLdr_Click" Margin="2"/>
                                    <Button Content="+ HC-SR04" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddUltrasonic_Click" Margin="2"/>
                                    <Button Content="+ Pot" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="AddPotentiometer_Click" Margin="2"/>
                                    
                                    <Separator Width="1" Height="15" Margin="5,0" Background="#3F3F46"/>
                                    
                                    <!-- Χρώμα Καλωδίου -->
                                    <TextBlock Text="Καλώδιο:" FontSize="10" VerticalAlignment="Center" Margin="2,0" Foreground="#A0A0A0"/>
                                    <ComboBox x:Name="WireColorComboBox" SelectedIndex="0" FontSize="10" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F46" Width="65" Height="20">
                                        <ComboBoxItem Content="Red" Tag="#FF3B30"/>
                                        <ComboBoxItem Content="Black" Tag="#000000"/>
                                        <ComboBoxItem Content="Blue" Tag="#007ACC"/>
                                        <ComboBoxItem Content="Green" Tag="#4CD964"/>
                                        <ComboBoxItem Content="Yellow" Tag="#FFCC00"/>
                                    </ComboBox>

                                    <Button Content="Clear" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="ClearCircuit_Click" Margin="10,0,2,0"/>
                                    
                                    <Separator Width="1" Height="15" Margin="5,0" Background="#3F3F46"/>
                                    <Button Content="🔍+" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="ZoomIn_Click" Margin="2" ToolTip="Zoom In"/>
                                    <Button Content="🔍-" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="ZoomOut_Click" Margin="2" ToolTip="Zoom Out"/>
                                    <Button Content="↺ Reset" Style="{StaticResource ModernButtonStyle}" FontSize="10" Click="ZoomReset_Click" Margin="2" ToolTip="Reset Zoom"/>
                                </WrapPanel>
                            </Border>

                            <!-- Καμβάς Σχεδίασης -->
                            <Border Grid.Row="1" Background="#161616" ClipToBounds="True">
                                <ScrollViewer x:Name="CanvasScrollViewer" 
                                              HorizontalScrollBarVisibility="Auto" 
                                              VerticalScrollBarVisibility="Auto"
                                              Background="Transparent"
                                              PreviewMouseWheel="CanvasScrollViewer_PreviewMouseWheel"
                                              MouseDown="CanvasScrollViewer_MouseDown"
                                              MouseMove="CanvasScrollViewer_MouseMove"
                                              MouseUp="CanvasScrollViewer_MouseUp">
                                    <Canvas x:Name="DesignCanvas" Width="1000" Height="750" Background="Transparent" ClipToBounds="True"
                                            MouseDown="DesignCanvas_MouseDown" 
                                            MouseMove="DesignCanvas_MouseMove"
                                            MouseUp="DesignCanvas_MouseUp">
                                        <Canvas.LayoutTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
                                            </TransformGroup>
                                        </Canvas.LayoutTransform>
                                    
                                    <!-- Σταθερή αναπαράσταση RPi Board -->
                                    <Border Canvas.Left="15" Canvas.Top="20" Background="#1D5C2C" BorderBrush="#0D3C14" BorderThickness="2" Width="65" Height="370" CornerRadius="6">
                                        <Grid>
                                            <TextBlock Text="RPi" Foreground="White" FontSize="9" FontWeight="Bold" Margin="3" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                            <TextBlock Text="Header" Foreground="#A0E0A0" FontSize="7" Margin="3,12,3,0" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                            
                                            <!-- Pin Header Background Area -->
                                            <Border Background="#1A1A1A" BorderBrush="#3A3A3C" BorderThickness="1" CornerRadius="2" Width="40" Height="335" Margin="0,25,0,5" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- ItemsControl για RPi Pins (Κύκλοι στον καμβά) -->
                                    <ItemsControl x:Name="PinsCanvasControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Background="Transparent"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="8" Height="8" Fill="#FFCC00" Stroke="#1A1A1A" StrokeThickness="1.5" Cursor="Hand" MouseDown="TerminalNode_MouseDown" Tag="{Binding PinNumber}">
                                                    <Ellipse.ToolTip>
                                                        <ToolTip Background="#2D2D2D" Foreground="White">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Pin " FontWeight="Bold"/>
                                                                    <TextBlock Text="{Binding PinNumber}" FontWeight="Bold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Name}"/>
                                                                <TextBlock Text="{Binding DisplayState}"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Ellipse.ToolTip>
                                                </Ellipse>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- ItemsControl για Wires (Καλώδια) -->
                                    <ItemsControl x:Name="WiresItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Background="Transparent"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Line X1="{Binding StartPoint.X}" Y1="{Binding StartPoint.Y}"
                                                          X2="{Binding EndPoint.X}" Y2="{Binding EndPoint.Y}"
                                                          StrokeThickness="3" Cursor="Hand" ToolTip="Δεξί κλικ για διαγραφή">
                                                        <Line.ContextMenu>
                                                            <ContextMenu Background="#2D2D2D" Foreground="White">
                                                                <MenuItem Header="Διαγραφή Καλωδίου" Click="DeleteWire_Click"/>
                                                            </ContextMenu>
                                                        </Line.ContextMenu>
                                                        <Line.Style>
                                                            <Style TargetType="Line">
                                                                <Setter Property="Stroke" Value="{Binding Color}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding State}" Value="HIGH">
                                                                        <Setter Property="Stroke" Value="#4CD964"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#4CD964" BlurRadius="8" ShadowDepth="0"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding State}" Value="LOW">
                                                                        <Setter Property="Stroke" Value="#0A84FF"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding State}" Value="ERROR">
                                                                        <Setter Property="Stroke" Value="#FF453A"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#FF453A" BlurRadius="8" ShadowDepth="0"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Line.Style>
                                                    </Line>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Προσωρινή γραμμή κατά το σύρσιμο καλωδίου -->
                                    <Line x:Name="TempWireLine" Stroke="#FFCC00" StrokeThickness="2.5" StrokeDashArray="2,1" Visibility="Collapsed"/>

                                    <!-- ItemsControl για Components (Εξαρτήματα) -->
                                    <ItemsControl x:Name="ComponentsCanvasControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Background="Transparent"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Visual Component Container -->
                                                <Border Width="60" Height="40" Background="#2D2D2D" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4"
                                                        PreviewMouseLeftButtonDown="Component_MouseDown"
                                                        PreviewMouseMove="Component_MouseMove"
                                                        PreviewMouseLeftButtonUp="Component_MouseUp"
                                                        Cursor="SizeAll" ToolTip="Δεξί κλικ για διαγραφή">
                                                    <Border.ContextMenu>
                                                        <ContextMenu Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F46">
                                                            <!-- Submenu αλλαγής χρώματος LED (εμφανίζεται μόνο για LED) -->
                                                            <MenuItem x:Name="ChangeColorMenu" Header="🎨  Αλλαγή Χρώματος LED" Background="#2D2D2D" Foreground="#E3E3E3">
                                                                <MenuItem Header="🔴  Κόκκινο"    Tag="red"    Click="ChangeLedColor_Click" Foreground="#FF3B30" FontWeight="SemiBold"/>
                                                                <MenuItem Header="🟢  Πράσινο"    Tag="green"  Click="ChangeLedColor_Click" Foreground="#4CD964" FontWeight="SemiBold"/>
                                                                <MenuItem Header="🟡  Κίτρινο"    Tag="yellow" Click="ChangeLedColor_Click" Foreground="#FFCC00" FontWeight="SemiBold"/>
                                                                <MenuItem Header="🔵  Μπλε"      Tag="blue"   Click="ChangeLedColor_Click" Foreground="#0A84FF" FontWeight="SemiBold"/>
