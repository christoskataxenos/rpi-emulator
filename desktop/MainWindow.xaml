                                                         </StackPanel.Style>
                                                         <TextBlock Text="Φωτεινότητα (%):" FontSize="9" Foreground="#A0A0A0"/>
                                                         <Slider Minimum="0" Maximum="100" Value="{Binding SensorValue, Mode=TwoWay}" ValueChanged="LdrSlider_ValueChanged" Height="18"/>
                                                     </StackPanel>

                                                     <StackPanel Margin="0,5,0,0">
                                                         <StackPanel.Style>
                                                             <Style TargetType="StackPanel">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Type}" Value="POTENTIOMETER">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </StackPanel.Style>
                                                         <TextBlock Text="Θέση Knob (%):" FontSize="9" Foreground="#A0A0A0"/>
                                                         <Slider Minimum="0" Maximum="100" Value="{Binding SensorValue, Mode=TwoWay}" ValueChanged="PotSlider_ValueChanged" Height="18"/>
                                                     </StackPanel>

                                                     <StackPanel Margin="0,5,0,0">
                                                         <StackPanel.Style>
                                                             <Style TargetType="StackPanel">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Type}" Value="ULTRASONIC">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </StackPanel.Style>
                                                         <TextBlock Text="Απόσταση:" FontSize="9" Foreground="#A0A0A0"/>
                                                         <Slider Minimum="0" Maximum="100" Value="{Binding SensorValue, Mode=TwoWay}" ValueChanged="UltrasonicSlider_ValueChanged" Height="18"/>
                                                     </StackPanel>
                                                 </StackPanel>

                                                 <!-- Press Button for Interactive Simulation -->
                                                 <Button Grid.Column="2" Content="Press" FontSize="9" Width="42" Height="20" Padding="1" VerticalAlignment="Center"
                                                         PreviewMouseDown="CompButton_PreviewMouseDown"
                                                         PreviewMouseUp="CompButton_PreviewMouseUp">
                                                     <Button.Style>
                                                         <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding Type}" Value="BUTTON">
                                                                     <Setter Property="Visibility" Value="Visible"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Button.Style>
                                                 </Button>

                                                 <!-- PIR Trigger Button -->
                                                 <Button Grid.Column="2" Content="Κίνηση" FontSize="9" Width="55" Height="20" Padding="1" VerticalAlignment="Center" Click="PirToggle_Click">
                                                     <Button.Style>
                                                         <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding Type}" Value="PIR">
                                                                     <Setter Property="Visibility" Value="Visible"/>
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding IsMotionActive}" Value="True">
                                                                     <Setter Property="Background" Value="#0A84FF"/>
                                                                     <Setter Property="Foreground" Value="White"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Button.Style>
                                                 </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>


        <!-- ================= ΔΕΞΙΑ ΣΤΗΛΗ ================= -->
        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="GPIO PINS (40-PIN HEADER)" Style="{StaticResource PanelHeaderStyle}"/>

            <Border Grid.Row="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <!-- Physical layout layout: Left (Odd) vs Right (Even) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column (Odd Pins) -->
                        <ItemsControl x:Name="OddPinsControl" Grid.Column="0" Margin="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PinItemStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Pin Circle -->
                                            <Ellipse Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="VCC5">
                                                                <Setter Property="Fill" Value="#C51A4A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="VCC3">
                                                                <Setter Property="Fill" Value="#E58F00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="GND">
                                                                <Setter Property="Fill" Value="#000000"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="GPIO">
                                                                <Setter Property="Fill" Value="#4A9E24"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!-- Pin number centered inside circle -->
                                            <TextBlock Text="{Binding PinNumber}" Foreground="White" FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Pin Info -->
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" Foreground="#E3E3E3"/>
                                                <TextBlock Text="{Binding DisplayState}" FontSize="9" Foreground="#A0A0A0"/>
                                            </StackPanel>

                                            <!-- Input simulator button -->
                                            <Button Grid.Column="2" Content="Press" FontSize="9" Padding="4,2" Margin="2,0,0,0"
                                                    Visibility="{Binding IsInput, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    PreviewMouseDown="InputButton_PreviewMouseDown"
                                                    PreviewMouseUp="InputButton_PreviewMouseUp"
                                                    Style="{StaticResource ModernButtonStyle}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Right Column (Even Pins) -->
                        <ItemsControl x:Name="EvenPinsControl" Grid.Column="1" Margin="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PinItemStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Input simulator button -->
                                            <Button Grid.Column="0" Content="Press" FontSize="9" Padding="4,2" Margin="0,0,2,0"
                                                    Visibility="{Binding IsInput, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    PreviewMouseDown="InputButton_PreviewMouseDown"
                                                    PreviewMouseUp="InputButton_PreviewMouseUp"
                                                    Style="{StaticResource ModernButtonStyle}"/>

                                            <!-- Pin Info (Right aligned layout for even column) -->
                                            <StackPanel Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" Foreground="#E3E3E3" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding DisplayState}" FontSize="9" Foreground="#A0A0A0" HorizontalAlignment="Right"/>
                                            </StackPanel>

                                            <!-- Pin Circle -->
                                            <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse Width="16" Height="16">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="VCC5">
                                                                    <Setter Property="Fill" Value="#C51A4A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="VCC3">
                                                                    <Setter Property="Fill" Value="#E58F00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="GND">
                                                                    <Setter Property="Fill" Value="#000000"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="GPIO">
                                                                    <Setter Property="Fill" Value="#4A9E24"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                
                                                <!-- Pin number centered inside circle -->
                                                <TextBlock Text="{Binding PinNumber}" Foreground="White" FontSize="9" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
    </DockPanel>
</Window>
